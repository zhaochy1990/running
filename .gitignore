__pycache__/
*.pyc

# Generated BP artifacts (regenerate via spec/_build_*.py)
spec/*.pdf
spec/*.pptx
spec/STRIDE_COACH_PRODUCT_VISION.html
*.egg-info/
dist/
build/
.pytest_cache/
.venv/
venv/
.coverage
.coverage.*
htmlcov/
# coach_cli local dev checkpointer (session state, never committed)
data/_coach_dev/
.claude/*
!.claude/commands/
.codex/
.composer/
.superpowers/
.omc/
.tmp/
*.un~
*~
# Anchored: only ignore a top-level `profile` directory (e.g. local
# scratch). Without the leading `/`, this rule was eating
# mobile/lib/features/profile/.
/profile
*.db
*.db-wal
*.db-shm
*.db-journal
data/*/config.json
data/*/auth.json
data/*/garmin_auth.json
data/*/coach.json
data/coach.json
data/*/onboarding.json
.stride-coach.json
.credentials.local
# Per-profile credential overrides (read by COROS / Garmin CLI, see
# docs/auth-wiring.md) — `--profile <name>`, same flat `email=…/password=…` format.
.credentials.*.local
.playwright-mcp/
tests/e2e/.shots/
# Root-level Playwright screenshots + snapshot dumps (local QA artifacts).
/*.png
/snapshot-*.yml
# Local migration backups produced by scripts/migrate_profile_to_english_keys.py
*.json.bak
*.json.bak.*
# Generated by `az bicep build --file infra/mysql-vm/main.bicep` during local validation.
/infra/mysql-vm/main.json
frontend/.env.local
frontend/.env.*.local
frontend/test-results/
# Anchored: only ignore a top-level `evaluation/` directory (local scratch).
# Without the leading `/`, this rule eats `src/coach/graphs/evaluation/` and
# any other nested `evaluation/` package — same bug pattern as `/profile` above.
/evaluation/
node_modules/
.worktrees/

data/*/testing/**
