[importlinter]
root_packages =
    coach
    coach_eval
    stride_server
    stride_core
    coros_sync
    garmin_sync
include_external_packages = True

# -----------------------------------------------------------------------------
# Contract 1: coach core isolation
#
# `coach.*` is the pure LangGraph runtime. It must NOT depend on any STRIDE
# infrastructure module — Azure SDKs, FastAPI, the SQLite DB layer, or any
# data-sync adapter. Domain primitives (plan_spec / workout_spec / plan_diff /
# master_plan / master_plan_diff) are allowed because they have no I/O.
#
# The reverse direction — `stride_server.coach_adapters` importing `coach.*` —
# is intentionally permitted and is how adapters bridge the two layers.
# -----------------------------------------------------------------------------
[importlinter:contract:coach-core-isolation]
name = Coach core must not import infrastructure modules
type = forbidden
source_modules =
    coach
forbidden_modules =
    stride_server
    coros_sync
    garmin_sync
    stride_core.db
    fastapi
    azure

# -----------------------------------------------------------------------------
# Contract 2: coach_eval is dev-only — nothing in production touches it
#
# `coach_eval.*` is the offline evaluation framework. It reuses production
# code (coach.* + stride_server.*) but the dependency direction is one-way:
# production must never import from coach_eval. This keeps the prod image
# free of eval baggage (judge prompts, fixture loaders, report renderers)
# and prevents an accidental dev-import from leaking into a route handler.
#
# The Dockerfile also strips `src/coach_eval/` from the prod build, but
# this contract is the static guard that catches drift earlier than build.
# -----------------------------------------------------------------------------
[importlinter:contract:coach-eval-dev-only]
name = Production modules must not import the offline eval framework
type = forbidden
source_modules =
    coach
    stride_server
    stride_core
    coros_sync
    garmin_sync
forbidden_modules =
    coach_eval
