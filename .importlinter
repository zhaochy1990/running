[importlinter]
root_packages =
    coach
    coach_eval
    stride_server
    stride_core
    stride_storage
    coros_sync
    garmin_sync
include_external_packages = True

# -----------------------------------------------------------------------------
# Contract 1: coach core isolation
#
# `coach.*` is the pure LangGraph runtime. It must NOT depend on any STRIDE
# infrastructure module — Azure SDKs, FastAPI, the SQLite DB layer, or any
# data-sync adapter. Domain primitives (plan_spec / workout_spec / plan_diff /
# master_plan / master_plan_diff) are allowed because they have no I/O.
#
# The reverse direction — `stride_server.coach_adapters` importing `coach.*` —
# is intentionally permitted and is how adapters bridge the two layers.
# -----------------------------------------------------------------------------
[importlinter:contract:coach-core-isolation]
name = Coach core must not import infrastructure modules
type = forbidden
source_modules =
    coach
forbidden_modules =
    stride_server
    coros_sync
    garmin_sync
    stride_core.db
    fastapi
    sqlalchemy
    pymysql
    azure

# -----------------------------------------------------------------------------
# Contract 2: coach_eval is dev-only — nothing in production touches it
#
# `coach_eval.*` is the offline evaluation framework. It reuses production
# code (coach.* + stride_server.*) but the dependency direction is one-way:
# production must never import from coach_eval. This keeps the prod image
# free of eval baggage (judge prompts, fixture loaders, report renderers)
# and prevents an accidental dev-import from leaking into a route handler.
#
# The Dockerfile also strips `src/coach_eval/` from the prod build, but
# this contract is the static guard that catches drift earlier than build.
# -----------------------------------------------------------------------------
[importlinter:contract:coach-eval-dev-only]
name = Production modules must not import the offline eval framework
type = forbidden
source_modules =
    coach
    stride_server
    stride_core
    coros_sync
    garmin_sync
forbidden_modules =
    coach_eval

# -----------------------------------------------------------------------------
# Contract 3: training-load core isolation
#
# `stride_core.training_load.core` and `stride_core.training_load.calibration`
# are pure-formula modules — they normalize HR / pace / power into TSS-like
# scale and walk an EWMA. They must not reach into DB, HTTP, vendor sync, or
# cloud SDKs. The only place that touches I/O is `training_load.adapter`,
# which deliberately depends on `stride_core.db` to load activities and
# upsert results. Keep the contamination out of the formula layer so the
# math stays unit-testable in isolation.
# -----------------------------------------------------------------------------
[importlinter:contract:training-load-core-isolation]
name = Training-load formulas must not import infrastructure modules
type = forbidden
source_modules =
    stride_core.training_load.core
    stride_core.training_load.calibration
    stride_core.training_load.types
forbidden_modules =
    stride_core.db
    stride_storage.sqlite
    stride_storage.mysql
    stride_storage.azure
    stride_storage.content
    stride_storage.keyvault
    stride_storage.coach_persistence
    stride_storage.factories
    stride_server
    coros_sync
    garmin_sync
    fastapi
    sqlalchemy
    pymysql
    azure

# -----------------------------------------------------------------------------
# Contract 4: running-calibration core isolation
#
# `stride_core.running_calibration.{core,segments,types,zones,repository}` are
# pure domain modules and repository protocol/orchestration. SQLite, HTTP,
# vendor sync, and cloud SDK details belong in replaceable connector modules.
# -----------------------------------------------------------------------------
[importlinter:contract:running-calibration-core-isolation]
name = Running-calibration core must not import infrastructure modules
type = forbidden
source_modules =
    stride_core.running_calibration.core
    stride_core.running_calibration.segments
    stride_core.running_calibration.types
    stride_core.running_calibration.zones
    stride_core.running_calibration.repository
    stride_core.running_calibration.prediction
forbidden_modules =
    stride_core.db
    stride_storage.sqlite
    stride_storage.mysql
    stride_storage.azure
    stride_storage.content
    stride_storage.keyvault
    stride_storage.coach_persistence
    stride_storage.factories
    stride_server
    coros_sync
    garmin_sync
    fastapi
    sqlalchemy
    pymysql
    azure

# -----------------------------------------------------------------------------
# Contract 5: coach must not import storage implementations
#
# `stride_storage` is the unified data-access layer. Its Tier-A `interfaces`
# subpackage (pure Protocols + frozen config dataclasses) is safe for the
# pure `coach` runtime to import. The implementation tiers, however, pull in
# `sqlite3` / Azure SDKs / Key Vault and must stay out of coach core — coach
# keeps receiving concrete stores via dependency injection from
# `stride_server.coach_adapters`. This guard lets coach use
# `stride_storage.interfaces` while blocking any accidental coupling to the
# heavy backends (Grimp detects function-level imports too, so the azure-free
# import chain is enforced).
# -----------------------------------------------------------------------------
[importlinter:contract:coach-no-storage-impl]
name = Coach must not import storage implementations (interfaces only)
type = forbidden
source_modules =
    coach
forbidden_modules =
    stride_storage.sqlite
    stride_storage.mysql
    stride_storage.azure
    stride_storage.content
    stride_storage.factories
    stride_storage.keyvault
    stride_storage.coach_persistence

# -----------------------------------------------------------------------------
# Contract 6: storage implementations never load server configuration
# -----------------------------------------------------------------------------
[importlinter:contract:storage-no-server-import]
name = Storage layer must not import server configuration
type = forbidden
source_modules =
    stride_storage
forbidden_modules =
    stride_server
